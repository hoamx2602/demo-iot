# ─── AI (Groq — free tier, 14,400 req/day, 30 RPM) ───
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=llama-3.3-70b-versatile   ← default (best quality)
# AI_MODEL=llama-3.1-8b-instant      ← faster, lighter

# ─── MQTT ─────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883

# ─── Email Alerts (Resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
ALERT_FROM=PumpGuard AI <onboarding@resend.dev>
ALERT_TO=engineer@yourcompany.com
# Multiple recipients: ALERT_TO=a@x.com,b@x.com

# ─── Public URL (set automatically by ngrok tunnel) ───
# PUBLIC_URL=https://xxxx.ngrok-free.app
