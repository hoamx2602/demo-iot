# ─── AI Provider ──────────────────────────────────────
# Chọn "claude" hoặc "openai"
AI_PROVIDER=claude

# Điền API key tương ứng:
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# OPENAI_API_KEY=sk-xxxx

# Model override (optional)
# AI_MODEL=claude-sonnet-4-6
# AI_MODEL=gpt-4o

# ─── MQTT ─────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883

# ─── Email Alerts (Resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
ALERT_FROM=PumpGuard AI <alerts@yourdomain.com>
ALERT_TO=engineer@yourcompany.com
# Nhiều địa chỉ: ALERT_TO=a@x.com,b@x.com

# ─── AWS deployment (optional) ────────────────────────
# MQTT_HOST=<ec2-public-ip>
# MQTT_PORT=1883
