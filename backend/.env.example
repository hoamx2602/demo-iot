# ─── AI Provider ──────────────────────────────────────
# Chọn một trong 3: "claude" | "openai" | "gemini"
AI_PROVIDER=gemini

# --- Option 1: Google Gemini (FREE tier, 15 req/min) ---
GEMINI_API_KEY=AIzaSy-xxxx
# AI_MODEL=gemini-1.5-flash         ← mặc định (nhanh + free)
# AI_MODEL=gemini-1.5-pro           ← mạnh hơn

# --- Option 2: Anthropic Claude ---
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# AI_MODEL=claude-sonnet-4-6

# --- Option 3: OpenAI ---
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxx
# AI_MODEL=gpt-4o

# ─── MQTT ─────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883

# ─── Email Alerts (Resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
ALERT_FROM=PumpGuard AI <alerts@yourdomain.com>
ALERT_TO=engineer@yourcompany.com
# Nhiều địa chỉ: ALERT_TO=a@x.com,b@x.com

# ─── AWS deployment (optional) ────────────────────────
# MQTT_HOST=<ec2-public-ip>
# MQTT_PORT=1883
